@ReciclaYa.Api_HostAddress = http://localhost:5021
@AccessToken = paste_jwt_access_token_here
@AdminAccessToken = paste_admin_jwt_access_token_here
@ListingId = paste_listing_id_here
@CompanyId = paste_company_id_here

# Confirmed frontend values:
# residueType/wasteType: organic, inorganic
# sector: agriculture, agroindustry, metallurgical, food, industrial
# productType: mango, coffee, cacao, grape
# exchangeType: sale, barter, pickup
# deliveryMode: warehouse_pickup, coordinated_delivery, third_party_transport
# condition/residueCondition: fresh, dry, wet, processed

GET {{ReciclaYa.Api_HostAddress}}/api/health
Accept: application/json

###

PUT {{ReciclaYa.Api_HostAddress}}/api/waste-sell/draft
Authorization: Bearer {{AccessToken}}
Content-Type: application/json

{
  "formValue": {
    "residueType": "organic",
    "sector": "agriculture",
    "productType": "mango",
    "specificResidue": "Mango fresco recuperable",
    "shortDescription": "Lote de mango fresco con valor de recuperacion para transformacion.",
    "volume": {
      "quantity": 120,
      "unit": "kg",
      "generationFrequency": "weekly",
      "estimatedCostPerUnit": 0.18
    },
    "logistics": {
      "warehouseAddress": "Piura, Peru",
      "maxStorageTime": "3 days",
      "exchangeType": "sale",
      "deliveryMode": "warehouse_pickup",
      "immediateAvailability": true
    },
    "additional": {
      "condition": "fresh",
      "restrictionsNotes": "Mantener en ambiente ventilado.",
      "nextAvailabilityDate": "2026-04-30"
    },
    "mediaUploads": [
      {
        "id": "sample-media-1",
        "name": "mango-lote.jpg",
        "previewUrl": "https://example.com/media/mango-lote.jpg",
        "sizeKb": 256,
        "type": "image/jpeg"
      }
    ]
  },
  "draftSavedAt": null,
  "aiSuggestionNote": null
}

###

POST {{ReciclaYa.Api_HostAddress}}/api/waste-sell/preview
Authorization: Bearer {{AccessToken}}
Content-Type: application/json

{
