GET {{ReciclaYa.Api_HostAddress}}/api/marketplace/listings?page=1&pageSize=12&wasteType=organic&sector=agroindustry&productType=cacao
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

GET {{ReciclaYa.Api_HostAddress}}/api/marketplace/listings?page=1&pageSize=12&wasteType=inorganic&sector=metallurgical&productType=grape
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

GET {{ReciclaYa.Api_HostAddress}}/api/marketplace/listings?page=1&pageSize=12&wasteType=organic&sector=food&productType=grape
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

GET {{ReciclaYa.Api_HostAddress}}/api/marketplace/listings/{{ListingId}}
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

GET {{ReciclaYa.Api_HostAddress}}/api/my-listings
Authorization: Bearer {{AccessToken}}
Accept: application/json

###

GET {{ReciclaYa.Api_HostAddress}}/api/admin/companies
Authorization: Bearer {{AdminAccessToken}}
Accept: application/json

###

PATCH {{ReciclaYa.Api_HostAddress}}/api/admin/companies/{{CompanyId}}/verify
Authorization: Bearer {{AdminAccessToken}}
Accept: application/json

###

PATCH {{ReciclaYa.Api_HostAddress}}/api/admin/companies/{{CompanyId}}/reject
Authorization: Bearer {{AdminAccessToken}}
Accept: application/json

